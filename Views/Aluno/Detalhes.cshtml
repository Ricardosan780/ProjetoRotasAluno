@{
    ViewData["Title"] = "Detalhes do Aluno";
}

<h2>Detalhes do Registro</h2>
<br /><br />

<div style="background-color: #f8f9fa; padding: 20px; border-left: 5px solid #28a745; max-width: 400px; display: block;">
    <span style="display: block; font-size: 18px; font-weight: bold; margin-bottom: 10px;">
        Buscando informações no servidor...
    </span>
    <br />
    <span style="display: block;">
        <strong>ID do Aluno Solicitado:</strong> @ViewBag.AlunoId
    </span>
</div>

<br /><br />
<p>
    <a href="/Aluno" style="display: inline-block; color: #007bff;"><- Voltar para o Perfil</a>
</p>